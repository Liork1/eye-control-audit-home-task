# Supabase project URL (base URL only — no /rest/v1/ suffix)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (required — all API DB access uses JWT + RLS)
SUPABASE_ANON_KEY=your-anon-key

# Must match Supabase Project Settings → API → JWT Secret
JWT_SECRET=your-jwt-secret

# Direct Postgres connection (required for db:migrate, db:seed, and bootstrap token insert)
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
