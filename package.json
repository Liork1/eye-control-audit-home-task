{
  "name": "audit-log-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:rls": "jest --testPathPattern=tests/rls",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "db:migrate": "tsx scripts/apply-schema.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:up": "docker compose --env-file docker/.env up -d",
    "db:down": "docker compose --env-file docker/.env down",
    "db:logs": "docker compose --env-file docker/.env logs -f",
    "db:reset": "docker compose --env-file docker/.env down -v && docker compose --env-file docker/.env up -d"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "jose": "^6.0.11",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/supertest": "^6.0.3",
    "babel-jest": "^30.4.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "jest": "^29.7.0",
    "pg": "^8.21.0",
    "supertest": "^7.1.1",
    "tailwindcss": "^4.1.8",
    "ts-jest": "^29.3.4",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
